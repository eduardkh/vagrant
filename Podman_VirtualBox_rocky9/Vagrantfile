BOX_IMAGE = "bento/rockylinux-9"
BOX_VERSION = "202510.26.0"
MEMORY = "8192"
CPU = "4"
# Use the Windows adapter name Vagrant resolves for bridged networking.
# The NIC description may exist, but Vagrant matches the adapter alias here.
# BRIDGE_INTERFACE = "Intel(R) Ethernet Controller (3) I225-V"
BRIDGE_INTERFACE = "Intel(R) Ethernet Connection (7) I219-V"
# & "C:\Program Files\Oracle\VirtualBox\VBoxManage.exe" list bridgedifs
IP = "10.200.14.251"
NETMASK = "255.255.248.0"
NETPREFIX = NETMASK.split(".").sum { |octet| octet.to_i.to_s(2).count("1") }
DEFAULT_GATEWAY = "10.200.15.254"
BOX_NAME = "rocky9"

Vagrant.configure("2") do |config|
  config.vm.define BOX_NAME do |subconfig|
    subconfig.vm.provider :virtualbox do |v|
      # v.gui = true
      v.customize ["modifyvm", :id, "--memory", MEMORY, "--cpus", CPU]
    end

    # Box configuration
    subconfig.vm.box = BOX_IMAGE
    subconfig.vm.box_version = BOX_VERSION
    subconfig.vm.box_check_update = false
    subconfig.vm.hostname = BOX_NAME
    
    # Public network configuration
    subconfig.vm.network :public_network, bridge: BRIDGE_INTERFACE, auto_config: false

    # Make the public NIC the preferred default route while leaving NAT as fallback.
    subconfig.vm.provision "shell", inline: <<-SHELL
      set -euo pipefail

      WAN_IP="#{IP}"
      WAN_PREFIX="#{NETPREFIX}"
      WAN_GW="#{DEFAULT_GATEWAY}"

      MGMT_DEV=$(ip route show default | awk '{ print $5; exit }')
      [ -n "$MGMT_DEV" ] || { echo "No default-route management device found"; exit 1; }

      WAN_DEV=$(nmcli -t -f DEVICE,TYPE device status \
        | awk -F: -v mgmt="$MGMT_DEV" '$2=="ethernet" && $1!=mgmt { print $1; exit }')
      [ -n "$WAN_DEV" ] || { echo "No bridged ethernet device found"; exit 1; }

      WAN_CON=$(nmcli -t -f NAME,DEVICE connection show | awk -F: -v dev="$WAN_DEV" '$2==dev { print $1; exit }')
      MGMT_CON=$(nmcli -t -f NAME,DEVICE connection show --active | awk -F: -v dev="$MGMT_DEV" '$2==dev { print $1; exit }')
      if [ -z "$WAN_CON" ]; then
        WAN_CON="System $WAN_DEV"
        sudo nmcli connection add type ethernet con-name "$WAN_CON" ifname "$WAN_DEV"
      fi
      [ -n "$MGMT_CON" ] || { echo "No active connection found for $MGMT_DEV"; exit 1; }

      sudo nmcli connection modify "$WAN_CON" \
        connection.autoconnect yes \
        connection.interface-name "$WAN_DEV" \
        ipv4.method manual \
        ipv4.addresses "$WAN_IP/$WAN_PREFIX" \
        ipv4.never-default no \
        ipv4.gateway "$WAN_GW" \
        ipv4.route-metric 10

      sudo nmcli connection modify "$MGMT_CON" \
        connection.autoconnect yes \
        connection.interface-name "$MGMT_DEV" \
        ipv4.route-metric 500

      sudo nmcli connection up "$WAN_CON"
      sudo nmcli connection up "$MGMT_CON" || true
    SHELL
  end

  # Update /etc/hosts to map hostname to IP
  config.vm.provision "shell", inline: <<-SHELL
    echo "#{IP} #{BOX_NAME}" | sudo tee -a /etc/hosts
  SHELL

  # install and configure Podman
  # config.vm.provision "shell", path: "install.sh", privileged: true
end
